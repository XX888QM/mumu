#!/Users/yunxin/jarvis/.venv/bin/python
# -*- coding: utf-8 -*-
"""木木 CLI（实施计划 1.15）。

用法：
    jarvis "指令"               # 新会话发指令，WS 流式打印执行过程
    jarvis -s <session_id> "指令"   # 续会话
    jarvis --status             # 系统状态表格
    jarvis --approvals          # 列 pending 授权 + 交互式 y/n 决定

token/端口从项目根 .env 读取（脚本定位自身路径 → 项目根）。
"""
import argparse
import json
import sys
from pathlib import Path

# cli/jarvis → 项目根
ROOT = Path(__file__).resolve().parent.parent

CYAN = "\033[36m"
RED = "\033[31m"
DIM = "\033[2m"
RESET = "\033[0m"


def load_env(env_file=None) -> dict:
    """极简 .env 解析（KEY=VALUE，支持引号与 # 注释行）。"""
    env: dict = {}
    path = Path(env_file) if env_file else ROOT / ".env"
    if not path.exists():
        return env
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key.strip()] = value.strip().strip('"').strip("'")
    return env


def get_config() -> tuple:
    """返回 (base_url, token)。"""
    env = load_env()
    port = int(env.get("JARVIS_PORT", "8777"))
    token = env.get("JARVIS_TOKEN", "")
    return f"http://127.0.0.1:{port}", token


def _headers(token: str) -> dict:
    return {"Authorization": f"Bearer {token}"}


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="jarvis", description="木木 CLI —— 大哥的命令行管家")
    p.add_argument("message", nargs="?", help="发给木木的指令")
    p.add_argument("-s", "--session", help="续会话的 session_id")
    p.add_argument("--status", action="store_true", help="打印系统状态")
    p.add_argument("--approvals", action="store_true", help="列出并决定 pending 授权")
    return p


# ---------------------------------------------------------------------------
# chat：POST /api/chat + WS 流式打印
# ---------------------------------------------------------------------------

def _print_event(event: dict) -> None:
    """按 1.15 要求渲染单条 codex 事件：[命令] $ ... / 输出尾行 / 工具调用。"""
    etype = event.get("type", "")
    item = event.get("item") or {}
    itype = item.get("type", "")
    if etype == "item.started" and itype == "command_execution":
        print(f"[命令] $ {item.get('command', '')}")
    elif etype == "item.completed":
        if itype == "command_execution":
            output = (item.get("aggregated_output") or "").rstrip()
            for line in output.splitlines()[-5:]:  # 只打输出尾行
                print(f"{DIM}       {line}{RESET}")
        elif itype == "agent_message":
            pass  # 最终消息由 task_done 统一打印，中间消息不重复刷屏
        elif itype == "mcp_tool_call":
            name = item.get("tool") or item.get("name") or "mcp_tool_call"
            print(f"[工具] {name}")


def cmd_chat(args) -> int:
    import httpx
    from websockets.exceptions import ConnectionClosed
    from websockets.sync.client import connect

    base, token = get_config()
    ws_url = base.replace("http://", "ws://") + "/ws"
    try:
        with connect(ws_url) as ws:
            # 契约 1.12（安全修订）：连接后首条消息认证，token 不走 URL query
            ws.send(json.dumps({"type": "auth", "token": token}))
            payload = {"message": args.message}
            if args.session:
                payload["session_id"] = args.session
            r = httpx.post(f"{base}/api/chat", json=payload,
                           headers=_headers(token), timeout=30)
            if r.status_code == 409:
                print(f"{RED}该会话有任务正在执行（busy），稍后再试{RESET}")
                return 1
            if r.status_code != 202:
                print(f"{RED}请求失败 {r.status_code}: {r.text}{RESET}")
                return 1
            data = r.json()
            task_id = data["task_id"]
            print(f"{DIM}任务 {task_id} | 会话 {data['session_id']}{RESET}")

            while True:
                msg = json.loads(ws.recv())
                mtype = msg.get("type")
                if mtype == "task_event" and msg.get("task_id") == task_id:
                    _print_event(msg.get("event") or {})
                elif mtype == "task_done" and msg.get("task_id") == task_id:
                    if msg.get("status") == "done":
                        print(f"{CYAN}{msg.get('result', '')}{RESET}")
                        usage = msg.get("usage") or {}
                        if usage:
                            print(f"{DIM}tokens: in={usage.get('input_tokens', 0)} "
                                  f"out={usage.get('output_tokens', 0)}{RESET}")
                        return 0
                    print(f"{RED}任务{msg.get('status')}{RESET}")
                    return 1
    except ConnectionClosed as exc:
        # 服务端主动关闭：4401=token 错误（契约 1.12），其余按异常断开处理
        if getattr(getattr(exc, "rcvd", None), "code", None) == 4401:
            print(f"{RED}token 错误（WS 4401），请检查 .env 的 JARVIS_TOKEN{RESET}")
        else:
            print(f"{RED}连接被服务端关闭：{exc}{RESET}")
        return 1
    except OSError as exc:  # ConnectionError 是 OSError 子类，一并覆盖网络类错误
        print(f"{RED}连不上木木服务：{exc}{RESET}")
        return 1


# ---------------------------------------------------------------------------
# --status：GET /api/system 表格打印
# ---------------------------------------------------------------------------

def _fmt_uptime(seconds) -> str:
    seconds = int(seconds)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h}h{m:02d}m{s:02d}s" if h else (f"{m}m{s:02d}s" if m else f"{s}s")


def cmd_status() -> int:
    import httpx

    base, token = get_config()
    r = httpx.get(f"{base}/api/system", headers=_headers(token), timeout=10)
    if r.status_code != 200:
        print(f"{RED}状态查询失败 {r.status_code}: {r.text}{RESET}")
        return 1
    d = r.json()
    rows = [
        ("CPU", f"{d['cpu_percent']}%"),
        ("内存", f"{d['mem_percent']}%"),
        ("磁盘", f"{d['disk_percent']}%"),
        ("运行时长", _fmt_uptime(d["uptime_sec"])),
        ("codex", d["codex_auth"]),
        ("活动任务", str(d["active_tasks"])),
    ]
    print(f"{CYAN}木木 系统状态{RESET}")
    print("-" * 30)
    for key, value in rows:
        print(f"{key:　<6}{value}")  # 全角空格对齐中文
    return 0


# ---------------------------------------------------------------------------
# --approvals：列 pending + 交互式 y/n
# ---------------------------------------------------------------------------

def cmd_approvals() -> int:
    import httpx

    base, token = get_config()
    r = httpx.get(f"{base}/api/approvals", params={"status": "pending"},
                  headers=_headers(token), timeout=10)
    if r.status_code != 200:
        print(f"{RED}查询失败 {r.status_code}: {r.text}{RESET}")
        return 1
    approvals = r.json()
    if not approvals:
        print("没有待批的授权请求")
        return 0
    for a in approvals:
        print(f"\n{RED}[{a['risk_level']}] {a['action']}{RESET}")
        print(f"  {a['detail']}")
        print(f"{DIM}  id={a['id']}  created={a['created_at']}{RESET}")
        answer = input("批准吗？[y=批准 / n=拒绝 / 回车=跳过] ").strip().lower()
        if answer == "y":
            decision = "approved"
        elif answer == "n":
            decision = "denied"
        else:
            print("跳过")
            continue
        rr = httpx.post(f"{base}/api/approvals/{a['id']}/decide",
                        json={"decision": decision}, headers=_headers(token), timeout=10)
        if rr.status_code == 200:
            print(f"{CYAN}已{('批准' if decision == 'approved' else '拒绝')}{RESET}")
        else:
            print(f"{RED}决定失败 {rr.status_code}: {rr.text}{RESET}")
    return 0


def main(argv=None) -> None:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.status:
        sys.exit(cmd_status())
    elif args.approvals:
        sys.exit(cmd_approvals())
    elif args.message:
        sys.exit(cmd_chat(args))
    else:
        parser.print_help()
        sys.exit(2)


if __name__ == "__main__":
    main()
