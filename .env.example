# 木木系统配置（复制为 .env 使用）
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8777
JARVIS_TOKEN=改成随机串-openssl_rand_hex_16
# Bark 推送：iPhone 装 Bark App，把 App 里的 device key 填这里；留空=推送降级为日志
BARK_KEY=
BARK_SERVER=https://api.day.app
CODEX_BIN=/Users/yunxin/.npm-global/bin/codex
JARVIS_MODEL=gpt-5.5
JARVIS_REASONING=high
JARVIS_SANDBOX=danger-full-access
JARVIS_TASK_TIMEOUT=3600
APPROVAL_TIMEOUT=1800

# ---- Phase 2 语音 ----
VOICE_ENABLED=1
TTS_PORT=8778
INDEX_TTS_DIR=/Users/yunxin/Desktop/开发/index-tts
# 木木音色参考音频：换音色=替换 workspace/voice/jarvis_ref.wav
ASR_MODEL=large-v3-turbo
# 唤醒词检测阈值（sherpa-onnx keywords_threshold）：误唤醒多→调大（0.35-0.5）；漏唤醒→调小
WAKE_THRESHOLD=0.25
